+// function names that come from an FName and may contain spaces or any
+// other non-identifier byte. Anything outside [A-Za-z0-9_] becomes '_'.
+static std::string SanitizeIdentifier(const std::string &in)
+{
+    std::string out;
+    out.reserve(in.size());
+    for (char c : in)
+    {
